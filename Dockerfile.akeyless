ARG OPENCLAW_TAG=latest
FROM ghcr.io/openclaw/openclaw:${OPENCLAW_TAG}

LABEL description="OpenClaw with Thales CipherTrust Secrets Manager integration (powered by Akeyless)"
LABEL maintainer="sanyambassi"

# Copy then strip CR — Windows checkouts often use CRLF; a \r in the shebang makes Linux report
# "exec …: no such file or directory" (it looks for /bin/sh\r).
COPY docker/akeyless-resolver.js /usr/local/bin/akeyless-resolver
COPY docker/rotation-webhook.js /usr/local/bin/rotation-webhook.js
COPY docker/entrypoint.sh /usr/local/bin/akeyless-entrypoint.sh
# Base image may run as non-root; sed -i writes temp files next to the target and fails in /usr/local/bin.
USER root
RUN set -e; \
  for f in /usr/local/bin/akeyless-entrypoint.sh /usr/local/bin/akeyless-resolver /usr/local/bin/rotation-webhook.js; do \
    sed 's/\r$//' "$f" > /tmp/crlf-fix.tmp && mv /tmp/crlf-fix.tmp "$f"; \
  done; \
  chmod 755 /usr/local/bin/akeyless-entrypoint.sh /usr/local/bin/akeyless-resolver /usr/local/bin/rotation-webhook.js; \
  chown 1000:1000 /usr/local/bin/akeyless-entrypoint.sh /usr/local/bin/akeyless-resolver /usr/local/bin/rotation-webhook.js
USER node

COPY --chown=1000:1000 docker/openclaw-akeyless.json /home/node/.openclaw/openclaw.json

ENTRYPOINT ["/usr/local/bin/akeyless-entrypoint.sh"]
CMD ["docker-entrypoint.sh", "node", "openclaw.mjs", "gateway", "--allow-unconfigured"]

# Runtime env vars (set by CipherTrust orchestration):
#   AKEYLESS_GATEWAY_URL    - CipherTrust Secrets Manager endpoint
#   AKEYLESS_ACCESS_ID      - Read-only access ID
#   AKEYLESS_ACCESS_KEY     - Corresponding access key
#
# Control UI: openclaw.json sets gateway.controlUi.allowedOrigins ["*"] for remote
# browser access; tighten before production if the gateway is reachable from untrusted networks.
#
# LLM API keys and the gateway auth token are resolved via
# OpenClaw's native SecretRef system (in-memory snapshot, no env vars).
# Web search only: entrypoint resolves CipherTrust websearch/* → BRAVE_API_KEY,
# FIRECRAWL_API_KEY, TAVILY_API_KEY, PERPLEXITY_API_KEY (in-memory; not in .env).
#
# Optional — per-provider baseUrl overrides:
#   <PROVIDER>_BASE_URL     - e.g. OPENAI_BASE_URL, ANTHROPIC_BASE_URL
#
# Optional — rotation webhook (disabled by default):
#   ROTATION_WEBHOOK_ENABLED     - "true" to enable
#   ROTATION_WEBHOOK_PORT        - default 9090
#   ROTATION_WEBHOOK_TOKEN       - shared secret for auth
#   ROTATION_WEBHOOK_COOLDOWN_MS - min ms between reloads (default 10000)
