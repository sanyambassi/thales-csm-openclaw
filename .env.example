# CipherTrust Secrets Manager endpoint (Akeyless Gateway URL)
AKEYLESS_GATEWAY_URL=https://your-ciphertrust-host/akeyless-api

# CipherTrust read-only credentials (used by OpenClaw resolver at runtime)
AKEYLESS_ACCESS_ID=p-xxxxxxxxxxxx
AKEYLESS_ACCESS_KEY=<reader-access-key>

# CipherTrust admin credentials (used by provision script only, NOT by the container)
# Set these if your admin role differs from the read-only role above.
# If not set, the provision script falls back to the read-only credentials.
# AKEYLESS_ADMIN_ACCESS_ID=p-xxxxxxxxxxxx
# AKEYLESS_ADMIN_ACCESS_KEY=<admin-access-key>

# Docker image tag (mirrors OpenClaw versions: 2026.3.13-1, latest, etc.)
OPENCLAW_AKEYLESS_TAG=latest

# Secret prefix in CipherTrust (default: /openclaw)
# AKEYLESS_SECRET_PREFIX=/openclaw

# Override image name (default: local build name; set for pre-built or registry images)
# OPENCLAW_IMAGE=sanyambassi/thales-csm-openclaw

# --- Rotation webhook (optional, uncomment when using rotated secrets) ---
# ROTATION_WEBHOOK_ENABLED=true
# ROTATION_WEBHOOK_PORT=9090
# ROTATION_WEBHOOK_TOKEN=<shared-secret-for-webhook-auth>
# ROTATION_WEBHOOK_COOLDOWN_MS=10000

# NOTE: This file is passed to the container at runtime. The container only
# uses AKEYLESS_GATEWAY_URL, AKEYLESS_ACCESS_ID, and AKEYLESS_ACCESS_KEY.
# The AKEYLESS_ADMIN_* variables are read by the provision script only and
# are ignored by the container.
